            <item row="0" column="0">
             <widget class="QLabel" name="label_10">
              <property name="styleSheet">
               <string notr="true">/* TRANG TRÍ Ô NHẬP LIỆU (QLineEdit) */
QLineEdit {
    background-color: #FFFFFF; /* Nền trắng sáng */
    border: 2px solid #CFD8DC; /* Viền xám nhạt, thanh lịch */
    
    /* Bo góc 15px (bằng đúng 1/2 chiều cao 30px đã set ở Bước 1) */
    border-radius: 15px; 
    
    /* Đẩy chữ thụt vào trong 15px để không bị dính vào góc bo tròn */
    padding: 2px 15px; 
    
    color: #333333; /* Màu chữ xám đen dễ đọc */
    font-size: 13px;
}

/* HIỆU ỨNG KHI CLICK VÀO ĐỂ GÕ CHỮ (Focus) */
QLineEdit:focus {
    border: 2px solid #1565C0; /* Đổi viền sang màu xanh dương đậm */
    background-color: #F8FBFF; /* Nền chuyển sang xanh nhạt rất êm mắt */
}

/* HIỆU ỨNG KHI Ô NHẬP BỊ KHÓA (ReadOnly / Disabled) */
QLineEdit:disabled, QLineEdit[readOnly=&quot;true&quot;] {
    background-color: #F5F5F5; /* Nền xám báo hiệu không được nhập */
    border: 2px solid #E0E0E0;
    color: #9E9E9E;
}</string>
